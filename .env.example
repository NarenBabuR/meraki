# Copy to .env and fill in. This is the ONLY required secret.
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Everything below is OPTIONAL — sensible defaults live in config.py.
# These are the Build / Break / Fix toggles. Override at the shell to run
# experiments without editing code, e.g.:
#   RERANK=false python scripts/run_eval.py --tag no_rerank
# ---------------------------------------------------------------------------

# Chunking (changing these requires re-running scripts/build_index.py)
# CHUNK_SIZE=1024
# CHUNK_OVERLAP_RATIO=0.2

# Embeddings
# EMBED_MODEL=BAAI/bge-small-en-v1.5
# USE_QUERY_INSTRUCTION=true        # Break #2: set false to drop BGE query asymmetry

# Retrieval
# TOP_N=25                          # wide candidate pool from vector search
# TOP_K=5                           # final chunks passed to the LLM
# SIM_THRESHOLD=0.30                # min cosine similarity to keep a candidate
# RERANK=true                       # Break #1: set false to disable cross-encoder rerank
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Generation / safety
# ABSTAIN=true                      # FIX: set false to remove the no-answer guardrail
# GEN_MODEL=claude-sonnet-4-6
# JUDGE_MODEL=claude-sonnet-4-6           # Ragas judge (set to a haiku id for cheaper eval)
ANONYMIZED_TELEMETRY=False
